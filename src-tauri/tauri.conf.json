{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buddy",
  "version": "0.1.0",
  "identifier": "com.xyzen.buddy",
  "build": {
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist",
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Buddy",
        "url": "index.html",
        "width": 800,
        "height": 600,
        "minWidth": 180,
        "minHeight": 240,
        "maxWidth": 1200,
        "maxHeight": 900,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "dragDropEnabled": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/silero_vad_v5.onnx"
    ]
  }
}
